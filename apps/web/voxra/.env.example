# ─── CALL-E (Required endpoints) ───────────────────────────────────────────────
# Default broker: https://seleven-mcp-sg.airudder.com
CALLE_BROKER_BASE_URL=https://seleven-mcp-sg.airudder.com

# Default MCP endpoint: https://seleven-mcp-sg.airudder.com/mcp/openagent_oauth
CALLE_MCP_URL=https://seleven-mcp-sg.airudder.com/mcp/openagent_oauth

# Request timeout in milliseconds for broker/MCP calls.
CALLE_TIMEOUT_MS=30000

# Strong application secret used for AES-256-GCM encryption of cookie payloads
# and Redis session/auth-state records. Use a high-entropy value.
CALLE_SESSION_ENCRYPTION_KEY=replace_with_32_byte_base64_or_strong_passphrase

# Redis configuration for distributed rate limiting and server-side session storage.
# Use either REDIS_URL or AZURE_REDIS_HOST + AZURE_REDIS_PASSWORD.
# REDIS_URL=rediss://:<password>@<redis-host>:6380

AZURE_REDIS_HOST=<redis-host>
AZURE_REDIS_PORT=6380
AZURE_REDIS_PASSWORD=replace_with_primary_or_secondary_access_key
AZURE_REDIS_TLS=true

# Optional legacy server token fallback (not required for normal browser login flow)
# CALLE_ACCESS_TOKEN=your_calle_access_token_here
